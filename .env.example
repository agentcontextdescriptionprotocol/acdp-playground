# Registries (default to docker-compose service names)
REGISTRY_A_URL=http://localhost:8100
REGISTRY_B_URL=http://localhost:8200
REGISTRY_A_AUTHORITY=registry-a.playground.local
REGISTRY_B_AUTHORITY=registry-b.playground.local

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: control plane (leave empty to disable).
# With `make up-full` these are set automatically to the compose service.
CONTROL_PLANE_URL=
CONTROL_PLANE_HMAC_SECRET=
# Admin bearer token for CP admin endpoints (introspection, revocation
# feed, pinned-key reload). Matches one of the CP's AUTH_ADMIN_API_KEYS.
CONTROL_PLANE_ADMIN_TOKEN=

# Webhook signing (must match registry config)
WEBHOOK_SECRET=playground-dev-secret

# ── V2 protocol features ────────────────────────────────────────────
# Default signing algorithm for agents that don't override it.
DEFAULT_SIGNATURE_ALG=ed25519
# Attach tenant context in tenancy-aware scenarios (off by default).
TENANCY_ENABLED=false
# JWT signing alg the registries/CP run with (informational on this side).
JWT_SIGNING_ALG=HS256

# ── Round-2 sibling sync (2026-06) ──────────────────────────────────
# The consumer SSRF guard (acdp_client.safe_http) is ON by default for
# data_refs[].location fetches: https-only, private/loopback/IMDS blocked,
# same-authority redirects, mixed-DNS-answer rejection. No env toggle —
# it is always enforced on the consumer fetch path (RFC-ACDP-0008 §4.9).
#
# Optional: point the JCS-vectors test at the sibling RFC repo. Defaults
# to ../agentcontextdescriptionprotocol; the test skips if absent.
# ACDP_RFC_DIR=../agentcontextdescriptionprotocol

# ── full-stack (make up-full) overrides — optional ──────────────────
# CONTROL_PLANE_JWT_SECRET=          # ≥32 bytes for the CP's HS256
# CONTROL_PLANE_API_KEY=playground-cp-api-key
# CONTROL_PLANE_TENANT_AGENTS=       # e.g. tenant-a:did:web:...,tenant-b:did:web:...
# DOMAIN_PACKS=finance
# POLICY_BACKEND=static

# ── Round-3 sibling sync (2026-06) — control-plane hardening knobs ──
# These map to the CP env added in acdp-control-plane #48/#49. They have
# secure-but-demo-friendly defaults baked into docker-compose.full.yml;
# override here only to exercise the stricter modes.
#
# Audience binding: the CP issues + enforces a JWT `aud` claim; a token
# minted for one authority is rejected by another (matches the registry).
# CONTROL_PLANE_JWT_AUDIENCE=control-plane.playground.local
# Strict tenancy: default-deny requests that resolve only to `default`.
# CONTROL_PLANE_AUTH_REQUIRE_TENANT=false
# Ingest DoS guards (pre-parse body-size + JSON-depth caps).
# CONTROL_PLANE_INGEST_MAX_BODY_BYTES=1048576
# CONTROL_PLANE_INGEST_MAX_JSON_DEPTH=32
# CONTROL_PLANE_INGEST_STRICT_TENANT=false
# Outbound-webhook SSRF policy (https-only / no-loopback by default).
# CONTROL_PLANE_WEBHOOK_SSRF_ALLOW_HTTP=false
# CONTROL_PLANE_WEBHOOK_SSRF_ALLOW_LOOPBACK=false
#
# Note: the registries now default to a loopback bind and refuse a
# non-loopback bind when both TLS and auth are off (registry #24). The
# playground configs keep bind = "0.0.0.0" with auth enabled, which is
# the explicit opt-in, so the demo stack is unaffected.

# Logging
LOG_FORMAT=pretty
LOG_LEVEL=INFO
