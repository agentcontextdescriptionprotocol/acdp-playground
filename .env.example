# Registries (default to docker-compose service names)
REGISTRY_A_URL=http://localhost:8100
REGISTRY_B_URL=http://localhost:8200
REGISTRY_A_AUTHORITY=registry-a.playground.local
REGISTRY_B_AUTHORITY=registry-b.playground.local

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: control plane (leave empty to disable).
# With `make up-full` these are set automatically to the compose service.
CONTROL_PLANE_URL=
CONTROL_PLANE_HMAC_SECRET=
# Admin bearer token for CP admin endpoints (introspection, revocation
# feed, pinned-key reload). Matches one of the CP's AUTH_ADMIN_API_KEYS.
CONTROL_PLANE_ADMIN_TOKEN=

# Webhook signing (must match registry config)
WEBHOOK_SECRET=playground-dev-secret

# ── V2 protocol features ────────────────────────────────────────────
# Default signing algorithm for agents that don't override it.
DEFAULT_SIGNATURE_ALG=ed25519
# Attach tenant context in tenancy-aware scenarios (off by default).
TENANCY_ENABLED=false
# JWT signing alg the registries/CP run with (informational on this side).
JWT_SIGNING_ALG=HS256

# ── full-stack (make up-full) overrides — optional ──────────────────
# CONTROL_PLANE_JWT_SECRET=          # ≥32 bytes for the CP's HS256
# CONTROL_PLANE_API_KEY=playground-cp-api-key
# CONTROL_PLANE_TENANT_AGENTS=       # e.g. tenant-a:did:web:...,tenant-b:did:web:...
# DOMAIN_PACKS=finance
# POLICY_BACKEND=static

# Logging
LOG_FORMAT=pretty
LOG_LEVEL=INFO
